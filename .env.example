# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AUDITEYE_LLM_API_KEY: Required for AI analysis and extraction features.
# Do NOT commit your real key. Use the platform secrets manager or a remote proxy.
AUDITEYE_LLM_API_KEY="your_api_key_here"

# AUDITEYE_LLM_BASE_URL: The base URL for the OpenAI-compatible model API.
AUDITEYE_LLM_BASE_URL="https://max.openai365.top/v1"

# AUDITEYE_LLM_BALANCE_URL: Optional URL to check API key balance.
AUDITEYE_LLM_BALANCE_URL="https://rmb.openai365.top"

# LLM Fallback configurations
AUDITEYE_PRIMARY_MODEL="gemini-2.5-pro"
AUDITEYE_FALLBACK_MODELS="gemini-3.1-pro-preview,gemini-3.1-pro-preview-maxthinking,gemini-3-pro-preview-thinking,claude-opus-4-6,claude-opus-4-6-thinking"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
