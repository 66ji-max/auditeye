# Environment variables for Vercel deployment with Neon and Vercel Blob

# 1. Neon PostgreSQL Database Connection
# You can get this string from your Neon Console (https://console.neon.tech).
# It typically looks like: postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require
DATABASE_URL=

# 2. Vercel Blob Token
# When deploying to Vercel, link the Vercel Blob store in the Storage tab of your project project,
# and it will automatically inject this. To run locally, you can use the token provided in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=
